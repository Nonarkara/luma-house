# Optional production persistence and analytics
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-anon-key
GOOGLE_SHEETS_ID=your-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email
GOOGLE_PRIVATE_KEY=your-private-key

# Concept photo API (Cloudflare Worker — see workers/concept-render)
# Client only needs the public Worker URL. Never put GEMINI_API_KEY in Vite envs.
VITE_CONCEPT_API_URL=https://luma-concept-render.YOUR_SUBDOMAIN.workers.dev

# Worker secrets (set with: cd workers/concept-render && wrangler secret put GEMINI_API_KEY)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-image
